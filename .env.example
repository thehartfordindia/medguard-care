# Local secrets — copy to .env and fill in. Never commit real values.
# All are OPTIONAL. The app runs fully with in-memory/file storage and no keys.

# Port the server listens on
PORT=8790

# Optional Postgres for durable storage (else falls back to local JSON file store)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Public website URL (used in links/meta). Defaults to http://localhost:8790
# WEBSITE_URL=https://your-medguard-app.onrender.com

# Admin/ops console secret (protects /api/admin/* endpoints)
ADMIN_SECRET=change-me

# ------------------------------------------------------------------
# Notifications (email + SMS) — ALL OPTIONAL.
# If nothing is set, the app skips sending (accounts/orders still work).
# ------------------------------------------------------------------

# Email via SendGrid: create a free account + API key + a verified sender.
# SENDGRID_API_KEY=SG.xxxxxxxx
# EMAIL_FROM=care@yourdomain.com
# EMAIL_FROM_NAME=MedGuard Care

# SMS via Twilio: account SID + auth token + a Twilio phone number.
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM_NUMBER=+1234567890

# Or route through your own gateway instead of SendGrid/Twilio:
# EMAIL_WEBHOOK_URL=https://your-gateway/email
# SMS_WEBHOOK_URL=https://your-gateway/sms

# Timeout (ms) for outbound notification calls
# NOTIFY_TIMEOUT_MS=8000

